# ============================================================
# Limarpoo E-commerce — Production Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
#
# Port mapping (docker-compose.yml):
#   postgres   → host:5443  container:5432
#   core       → host:5444  container:3000
#   storefront → host:5445  container:3001
#   landing    → host:5446  container:80
#   admin      → host:5447  container:80
#
# IMPORTANT: ADMIN_API_URL, VITE_API_URL, VITE_STOREFRONT_URL,
# and NEXT_PUBLIC_API_URL are baked in at Docker BUILD TIME.
# After changing them you must rebuild the images.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=limarpoo_core

# --- Core API (backend) ---
JWT_SECRET=your_jwt_secret_here
NODE_ENV=production

# --- Admin Dashboard (host:5447) ---
# Reachable by the browser — use your server's public IP or domain
ADMIN_API_URL=http://YOUR_SERVER_IP:5444/api/v1

# --- Landing Page (host:5446) ---
VITE_API_URL=http://YOUR_SERVER_IP:5444/api/v1
VITE_STOREFRONT_URL=http://YOUR_SERVER_IP:5445

# --- Storefront (host:5445) ---
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:5444

# Base URL of this API (used in Swagger UI server selector)
API_BASE_URL=http://localhost:3000

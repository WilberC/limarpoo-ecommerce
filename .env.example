# ============================================================
# Limarpoo E-commerce — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=limarpoo_core

# --- Core API (backend) ---
# Secret key used to sign JWT tokens
JWT_SECRET=your_jwt_secret_here
NODE_ENV=production

# --- Admin Dashboard ---
# URL of the Core API accessible FROM THE BROWSER (baked in at build time)
# When running in Docker on the same host, use the public IP or domain.
# Example for local Docker: http://localhost:3000/api/v1
ADMIN_API_URL=http://localhost:3000/api/v1

# --- Landing Page ---
# URL of the Core API accessible FROM THE BROWSER (baked in at build time)
VITE_API_URL=http://localhost:3000/api/v1
# URL of the Storefront accessible FROM THE BROWSER (baked in at build time)
VITE_STOREFRONT_URL=http://localhost:3001

# --- Storefront ---
# URL of the Core API accessible FROM THE BROWSER and SERVER (baked in at build time)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Base URL of this API (used in Swagger UI server selector)
API_BASE_URL=http://localhost:3000
